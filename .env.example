# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Twilio Notification Configuration (SMS + WhatsApp)
# Get credentials from https://console.twilio.com
# Server-side (for Vercel API routes): no VITE_ prefix
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here
TWILIO_WHATSAPP_NUMBER=whatsapp:your_twilio_whatsapp_number_here

# Client-side Twilio config (used by frontend notification service)
VITE_TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
VITE_TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
VITE_TWILIO_PHONE_NUMBER=your_twilio_phone_number_here
VITE_TWILIO_WHATSAPP_NUMBER=whatsapp:your_twilio_whatsapp_number_here

# Meta WhatsApp API Configuration (for template-based messages)
# Get credentials from https://developers.facebook.com/apps
META_PHONE_NUMBER_ID=your_meta_phone_number_id_here
META_WHATSAPP_TOKEN=your_meta_whatsapp_token_here
